<Page x:Class="MediProject_Client.GUI.PersonalArea"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MediProject_Client.GUI"
      mc:Ignorable="d"
      Title="Pharmacy Care - PersonalArea" Height="750" Width="550">

    <Border CornerRadius="20" Background="White" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="0" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,0">

                <Border Width="100" Height="45" CornerRadius="22.5" BorderBrush="#D1D1D1" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#2D9CDB" Offset="0.5"/>
                            <GradientStop Color="#27AE60" Offset="0.5"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <TextBlock Text="Pharmacy Care" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           FontFamily="Segoe UI" 
                           Foreground="#333" 
                           HorizontalAlignment="Center" 
                           Margin="0,15,0,0"/>

                <TextBlock Text="איזור אישי:" 
                           FontSize="18" 
                           FontFamily="Segoe UI" 
                           Foreground="#666" 
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,0" 
                           FlowDirection="RightToLeft"/>

                <TextBlock Text="{Binding UserName, StringFormat='שלום לך, {0}'}" 
                           FontSize="15" 
                           FontWeight="SemiBold"
                           FontFamily="Segoe UI" 
                           Foreground= "Black"
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,10" 
                           FlowDirection="RightToLeft"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="התרופות שלי:" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           FontFamily="Segoe UI" 
                           Foreground="#333" 
                           HorizontalAlignment="Right" 
                           FlowDirection="RightToLeft"
                           Margin="0,0,10,5"/>

                <Frame x:Name="PersonalMediListFrame" Grid.Row="1" NavigationUIVisibility="Hidden"/>
            </Grid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,10">
                <Button Click="Logout_Click" Content=" התנתקות"
                        Width="120"
                        Height="42"
                        Background="#DC3545"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Margin="0,0,10,0">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Click="AddMedication_Click" Content="✚ הוספת תרופה"
                        Width="120"
                        Height="42"
                        Background="#28A745"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Page>
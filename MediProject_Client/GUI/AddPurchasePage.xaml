<Page x:Class="MediProject_Client.GUI.AddPurchasePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="800"
      Title="הוספת תרופה"
      Background="#F9F9F9">

    <Page.Resources>
        <SolidColorBrush x:Key="BorderColor" Color="#CBD5E0"/>
        <SolidColorBrush x:Key="TextColor" Color="#4A5568"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#4A90E2"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#2ECC71"/>

        <!-- סגנון פשוט וישיר לכל תיבות הטקסט -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="קניית תרופה" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Foreground="#4A5568" 
                   HorizontalAlignment="Right" 
                   Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1" FlowDirection="RightToLeft">

            <Label Content="תרופה:" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Name="txtMedicationName" IsReadOnly="True" />

                <Button Grid.Column="1" 
                        Content="בחר..." 
                        Width="70" 
                        Margin="8,0,0,0"
                        Background="{StaticResource AccentBlue}" 
                        Foreground="White" 
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="SelectMedication_Click"/>
            </Grid>

            <Label Content="מספר כדורים בחפיסה:" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
            <TextBox Name="txtPillsAmount" Margin="0,0,0,15" InputScope="Number"/>

            <Label Content="מספר כדורים ביום:" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
            <TextBox Name="txtPillsPerDay" Margin="0,0,0,15" InputScope="Number"/>

            <Label Content="תאריך קנייה:" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
            <DatePicker Name="dpPurchaseDate" Margin="0,0,0,15"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,15,0,0">

            <Button Content="שמור תרופה" 
                    Width="120" Height="38" 
                    Background="{StaticResource SuccessGreen}" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SaveButton_Click" Margin="0,0,10,0"/>

            <Button Content="ביטול" 
                    Width="90" Height="38" 
                    Background="White" 
                    Foreground="{StaticResource TextColor}" 
                    FontWeight="SemiBold" 
                    BorderThickness="1"
                    BorderBrush="{StaticResource BorderColor}"
                    Cursor="Hand"
                    Click="CancelButton_Click"/>

        </StackPanel>
    </Grid>
</Page>
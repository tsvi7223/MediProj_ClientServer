<Page x:Class="MediProject_Client.GUI.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MediProject_Client.GUI"
      mc:Ignorable="d" 
      Title="Pharmacy Care - Login"
      FlowDirection="RightToLeft">

    <Border Background="White">
        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30">
                <Border Width="100" Height="45" CornerRadius="22.5" BorderBrush="#D1D1D1" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#2D9CDB" Offset="0.5"/>
                            <GradientStop Color="#27AE60" Offset="0.5"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <TextBlock Text="Pharmacy Care" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           FontFamily="Segoe UI" 
                           Foreground="#333" 
                           HorizontalAlignment="Center" 
                           Margin="0,15,0,0"/>

                <TextBlock Text="התחברות למערכת" 
                           FontSize="18" 
                           FontFamily="Segoe UI" 
                           Foreground="#666" 
                           HorizontalAlignment="Center" 
                           Margin="0,10,0,0"/>
            </StackPanel>

            <StackPanel x:Name="LoginPanel" Grid.Row="1" VerticalAlignment="Top" MaxWidth="400">
                <TextBlock Text="שם משתמש:" Margin="0,5,0,0" FontWeight="SemiBold"/>
                <TextBox x:Name="LoginUser" Margin="0,5,0,15" Height="40" VerticalContentAlignment="Center" FontSize="14"/>

                <TextBlock Text="סיסמה:" Margin="0,5,0,0" FontWeight="SemiBold"/>
                <PasswordBox x:Name="LoginPass" Margin="0,5,0,20" Height="40" VerticalContentAlignment="Center" FontSize="14"/>

                <Button Content="התחבר" Background="#2D9CDB" Foreground="White" Height="45" 
                        FontWeight="Bold" FontSize="16" Cursor="Hand" Click="BtnLogin_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock Text="עדיין לא רשום? צור חשבון" Foreground="#2D9CDB" Cursor="Hand" 
                           HorizontalAlignment="Center" Margin="0,20,0,0" MouseLeftButtonUp="ShowRegister_Click" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>
    </Border>
</Page>
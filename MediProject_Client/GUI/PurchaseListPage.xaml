<Page x:Class="MediProject_Client.GUI.PurchaseListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MediProject_Client.GUI"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="MedicationsList">

    <Grid Background="WhiteSmoke">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.Margin>20</Grid.Margin>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <TextBox Name="txtSearch" Height="35" Padding="10,5" VerticalContentAlignment="Center" FontSize="14" TextChanged="TxtSearch_TextChanged"/>
        </Grid>
        <TextBlock Text="הקניות שלי" FontSize="20"/>
        <ListView Grid.Row="1" Name="listView" BorderThickness="0">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Medicine Name:" DisplayMemberBinding="{Binding medication.OriginalName}" Width="100"/>
                    <GridViewColumn Header="Purchase Date:" DisplayMemberBinding="{Binding PurchaseDate}" Width="110"/>
                    <GridViewColumn Header="Pills Per Day:" DisplayMemberBinding="{Binding PillsPerDay}" Width="140"/>
                    <GridViewColumn Header="Pill Amount:" DisplayMemberBinding="{Binding PillAmount}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
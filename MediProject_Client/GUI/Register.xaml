<Page x:Class="MediProject_Client.GUI.Register"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MediProject_Client.GUI"
      mc:Ignorable="d" 
            Title="Pharmacy Care - Login" Height="650" Width="450" >


    <Grid>
        <Border CornerRadius="20" Background="White" Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="0" ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>

            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,20">


                    <Border Width="100" Height="45" CornerRadius="22.5" BorderBrush="#D1D1D1" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#2D9CDB" Offset="0.5"/>
                                <GradientStop Color="#27AE60" Offset="0.5"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <TextBlock Text="Pharmacy Care" 
             FontSize="28" 
             FontWeight="Bold" 
             FontFamily="Segoe UI" 
             Foreground="#333" 
             HorizontalAlignment="Center" 
             Margin="0,15,0,0"/>

                    <TextBlock Text="התחברות למערכת:" 
             FontSize="18" 
             FontFamily="Segoe UI" 
             Foreground="#666" 
             HorizontalAlignment="Center" 
             Margin="0,10,0,0" 
             FlowDirection="RightToLeft"/>
                </StackPanel>
                <ScrollViewer Grid.Row="1" x:Name="RegisterPanel"  VerticalScrollBarVisibility="Auto" Padding="60,0,0,0">
            <StackPanel Margin="10">
                <TextBlock Text="הרשמה למערכת" FontSize="18" Foreground="#666" Margin="0,0,0,25" HorizontalAlignment="Right"/>
                <TextBlock Text=":שם משתמש" HorizontalAlignment="Right"/>
                        <TextBox x:Name="RegUser" Text="{Binding UserName}" Margin="0,5" Height="35" VerticalContentAlignment="Center"/>
                <TextBlock Text=":אימייל" HorizontalAlignment="Right"/>
                        <TextBox x:Name="RegMail" Text="{Binding Gmail}" Margin="0,5" Height="35" VerticalContentAlignment="Center"/>
                <TextBlock Text=":מקום מגורים" HorizontalAlignment="Right"/>
                        <TextBox x:Name="RegCity" Text="{Binding FullAddress}" Margin="0,5" Height="35" VerticalContentAlignment="Center"/>
                <TextBlock Text=":מספר טלפון" HorizontalAlignment="Right"/>
                        <TextBox x:Name="RegPhone" Text="{Binding PhoneNumber}" Margin="0,5" Height="35" VerticalContentAlignment="Center"/>
                <TextBlock Text=":בחר קופת חולים" Margin="0,10,0,5" HorizontalAlignment="Right"/>
                        <ComboBox x:Name="RegHMO" Margin="0,0,0,10" Height="35" SelectionChanged="RegHMO_SelectionChanged">
                    <ComboBoxItem Content="כללית" Tag="1"/>
                    <ComboBoxItem Content="מכבי" Tag="2"/>
                    <ComboBoxItem Content="מאוחדת" Tag="3"/>
                    <ComboBoxItem Content="לאומית" Tag="4"/>
                </ComboBox>
                <TextBlock Text="סיסמה:" HorizontalAlignment="Right"/>
                        <PasswordBox x:Name="RegPass" Margin="0,5" Height="35" VerticalContentAlignment="Center"/>
                <Button Content="סיום הרשמה" Background="#27AE60" Foreground="White" Height="40" Margin="0,15,0,5" Click="BtnFinishRegister_Click"/>
                <TextBlock Text="חזור להתחברות" Foreground="#666" Cursor="Hand" HorizontalAlignment="Center" MouseLeftButtonUp="BackToLogin_Click"  Margin="0,5"/>
            </StackPanel>
        </ScrollViewer>

            </Grid>
        </Border>
        
    </Grid>
</Page>

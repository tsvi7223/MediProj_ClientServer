
    <Window x:Class="ProjectOfMedicine_Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectOfMedicine_Client"
        mc:Ignorable="d"
        Title="Pharmacy Care - Login" Height="650" Width="450" 
        WindowStartupLocation="CenterScreen" Background="#F5F7FA">


        <Border CornerRadius="20" Background="White" Margin="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Direction="0" ShadowDepth="0" Opacity="0.2"/>
            </Border.Effect>

            <Grid Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,20">


                    <Border Width="100" Height="45" CornerRadius="22.5" BorderBrush="#D1D1D1" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#2D9CDB" Offset="0.5"/>
                                <GradientStop Color="#27AE60" Offset="0.5"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <TextBlock Text="Pharmacy Care" 
               FontSize="28" 
               FontWeight="Bold" 
               FontFamily="Segoe UI" 
               Foreground="#333" 
               HorizontalAlignment="Center" 
               Margin="0,15,0,0"/>

                    <TextBlock Text="התחברות למערכת:" 
               FontSize="18" 
               FontFamily="Segoe UI" 
               Foreground="#666" 
               HorizontalAlignment="Center" 
               Margin="0,10,0,0" 
               FlowDirection="RightToLeft"/>
                </StackPanel>
                <StackPanel x:Name="LoginPanel" Grid.Row="1" Visibility="Visible">
                    <TextBlock Text="התחברות" FontSize="18" Foreground="#666" Margin="0,0,0,20" HorizontalAlignment="Right"/>
                    <TextBlock Text=":תעודת זהות" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                    <TextBox x:Name="LoginUser" Margin="0,5" Height="40" VerticalContentAlignment="Center"/>
                    <TextBlock Text=":סיסמה" HorizontalAlignment="Right" Margin="0,10,0,0"/>
                    <PasswordBox x:Name="LoginPass" Margin="0,5" Height="40" VerticalContentAlignment="Center"/>
                    <Button Content="התחבר" Background="#2D9CDB" Foreground="White" Height="40" Margin="0,20,0,10" Click="BtnLogin_Click"/>
                    <TextBlock Text="עדיין לא רשום? צור חשבון" Foreground="#2D9CDB" Cursor="Hand" HorizontalAlignment="Center" MouseLeftButtonUp="ShowRegister_Click"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" x:Name="RegisterPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="60,0,0,0">
                    <StackPanel>
                        <TextBlock Text="הרשמה למערכת" FontSize="18" Foreground="#666" Margin="0,0,0,25" HorizontalAlignment="Right"/>
                        <TextBlock Text=":שם משתמש" HorizontalAlignment="Right"/>
                        <TextBox x:Name="RegUser" Margin="0,5" Height="35" VerticalContentAlignment="Center"/>
                        <TextBlock Text=":אימייל" HorizontalAlignment="Right"/>
                        <TextBox x:Name="RegMail" Margin="0,5" Height="35" VerticalContentAlignment="Center"/>
                        <TextBlock Text=":מקום מגורים" HorizontalAlignment="Right"/>
                        <TextBox x:Name="RegCity" Margin="0,5" Height="35" VerticalContentAlignment="Center"/>
                        <TextBlock Text=":מספר טלפון" HorizontalAlignment="Right"/>
                        <TextBox x:Name="RegPhone" Margin="0,5" Height="35" VerticalContentAlignment="Center"/>
                        <TextBlock Text=":בחר קופת חולים" Margin="0,10,0,5" HorizontalAlignment="Right"/>
                        <ComboBox x:Name="RegHMO" Margin="0,0,0,10" Height="35">
                            <ComboBoxItem Content="כללית"/>
                            <ComboBoxItem Content="מכבי"/>
                            <ComboBoxItem Content="מאוחדת"/>
                            <ComboBoxItem Content="לאומית"/>
                        </ComboBox>
                        <TextBlock Text="סיסמה:" HorizontalAlignment="Right"/>
                        <PasswordBox x:Name="RegPass" Margin="0,5" Height="35" VerticalContentAlignment="Center"/>
                        <Button Content="סיום הרשמה" Background="#27AE60" Foreground="White" Height="40" Margin="0,15,0,5" Click="BtnFinishRegister_Click"/>
                        <TextBlock Text="חזור להתחברות" Foreground="#666" Cursor="Hand" HorizontalAlignment="Center" MouseLeftButtonUp="ShowLogin_Click" Margin="0,5"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

    </Window>

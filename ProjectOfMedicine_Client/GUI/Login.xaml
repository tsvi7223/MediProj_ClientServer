<Page x:Class="ProjectOfMedicine_Client.GUI.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ProjectOfMedicine_Client.GUI"
      mc:Ignorable="d" 
      Title="Pharmacy Care - Login" Height="650" Width="450" >


    <Border CornerRadius="20" Background="White" Margin="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="0" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,20">


                <Border Width="100" Height="45" CornerRadius="22.5" BorderBrush="#D1D1D1" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#2D9CDB" Offset="0.5"/>
                            <GradientStop Color="#27AE60" Offset="0.5"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <TextBlock Text="Pharmacy Care" 
               FontSize="28" 
               FontWeight="Bold" 
               FontFamily="Segoe UI" 
               Foreground="#333" 
               HorizontalAlignment="Center" 
               Margin="0,15,0,0"/>

                <TextBlock Text="התחברות למערכת:" 
               FontSize="18" 
               FontFamily="Segoe UI" 
               Foreground="#666" 
               HorizontalAlignment="Center" 
               Margin="0,10,0,0" 
               FlowDirection="RightToLeft"/>
            </StackPanel>
            <StackPanel x:Name="LoginPanel" Grid.Row="1" Visibility="Visible">
                <TextBlock Text="התחברות" FontSize="18" Foreground="#666" Margin="0,0,0,20" HorizontalAlignment="Right"/>
                <TextBlock Text=":תעודת זהות" HorizontalAlignment="Right" Margin="0,5,0,0"/>
                <TextBox x:Name="LoginUser" Margin="0,5" Height="40" VerticalContentAlignment="Center"/>
                <TextBlock Text=":סיסמה" HorizontalAlignment="Right" Margin="0,10,0,0"/>
                <PasswordBox x:Name="LoginPass" Margin="0,5" Height="40" VerticalContentAlignment="Center"/>
                <Button Content="התחבר" Background="#2D9CDB" Foreground="White" Height="40" Margin="0,20,0,10" Click="BtnLogin_Click"/>
                <TextBlock Text="עדיין לא רשום? צור חשבון" Foreground="#2D9CDB" Cursor="Hand" HorizontalAlignment="Center" MouseLeftButtonUp="ShowRegister_Click"/>
            </StackPanel>

        </Grid>
    </Border>
</Page>

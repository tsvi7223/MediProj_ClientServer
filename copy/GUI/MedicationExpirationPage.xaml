<Page x:Class="MediProject_Client.GUI.MedicationExpirationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="MedicationExpirationPage"
      FlowDirection="RightToLeft">

    <Grid Background="WhiteSmoke">
        <Grid.Margin>20</Grid.Margin>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="מתי לקנות תרופה:" FontSize="20" FontWeight="Regular" Foreground="#333" Margin="0,0,0,10"/>

        <ListView Grid.Row="1" Name="medicationExpirationList" BorderThickness="0" Background="Transparent">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="שם תרופה" DisplayMemberBinding="{Binding MedicationName}" Width="150"/>
                    <GridViewColumn Header="תאריך סיום משוער" DisplayMemberBinding="{Binding ExpirationDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</Page>
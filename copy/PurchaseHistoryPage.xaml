<Page x:Class="MediProject_Client.GUI.PurchaseHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MediProject_Client.GUI"
      mc:Ignorable="d"
      Title="Pharmacy Care - PurchaseHistory" 
      MinHeight="600" MinWidth="400"
      FlowDirection="RightToLeft">

    <Border CornerRadius="0" Background="White">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="20">
                <Border Width="80" Height="35" CornerRadius="17.5" BorderBrush="#D1D1D1" BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#2D9CDB" Offset="0.5"/>
                            <GradientStop Color="#27AE60" Offset="0.5"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <TextBlock Text="Pharmacy Care" FontSize="24" FontWeight="Bold" Foreground="#333" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                <TextBlock Text="היסטוריית קניות:" FontSize="16" FontWeight="Normal" Foreground="#888" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <ListView Grid.Row="1" Name="purchaseListView" Margin="20" BorderThickness="0" Background="Transparent">
                <ListView.View>
                    <GridView>
                        <GridView.ColumnHeaderContainerStyle>
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="FontWeight" Value="Normal"/>
                            </Style>
                        </GridView.ColumnHeaderContainerStyle>

                        <GridViewColumn Header="שם תרופה" DisplayMemberBinding="{Binding medication.OriginalName}" Width="120"/>
                        <GridViewColumn Header="תאריך קניה" DisplayMemberBinding="{Binding PurchaseDate, StringFormat='{}{0:dd/MM/yyyy}'}" Width="110"/>
                        <GridViewColumn Header="כדורים ליום" DisplayMemberBinding="{Binding PillsPerDay}" Width="100"/>
                        <GridViewColumn Header="סה״כ כדורים" DisplayMemberBinding="{Binding PillAmount}" Width="100"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button Content="חזרה לאיזור האישי" Width="150" Height="40" Background="#6C757D" Foreground="White" 
                        FontWeight="Bold" BorderThickness="0" Click="BtnBack_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Page>